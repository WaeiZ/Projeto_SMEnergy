import 'package:flutter/material.dart';
import 'package:smenergy/widgets/custom_widgets.dart'; // Ajusta o caminho se necessário

class RegisterPage extends StatefulWidget {
  const RegisterPage({super.key});

  @override
  State<RegisterPage> createState() => _RegisterPageState();
}

class _RegisterPageState extends State<RegisterPage> {
  // Estados para controlar a visibilidade das duas passwords
  bool _isObscure = true;
  bool _isObscureConfirm = true;

  @override
  Widget build(BuildContext context) {
    // Usamos o gradiente que definiste no teu ficheiro de widgets
    final myGradient = AppGradients.blueLinear;

    return Scaffold(
      backgroundColor: Colors.white,
      // AppBar apenas para o botão de voltar (seta)
      appBar: AppBar(
        backgroundColor: Colors.transparent,
        elevation: 0,
        leading: IconButton(
          icon: const Icon(Icons.arrow_back_ios_new, color: Colors.black, size: 20),
          onPressed: () => Navigator.pop(context),
        ),
      ),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: const EdgeInsets.symmetric(horizontal: 24.0),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.stretch,
            children: [
              // LOGO (Igual ao da Login Page)
              Center(
                child: Image.asset(
                  'assets/logo.png',
                  height: 200,
                  fit: BoxFit.contain,
                ),
              ),

              const SizedBox(height: 10),

              // TÍTULO "Registo"
              const Text(
                'Registo',
                style: TextStyle(
                  fontSize: 26,
                  fontWeight: FontWeight.bold,
                  color: Colors.black,
                ),
              ),

              const SizedBox(height: 25),

              // CAMPO EMAIL
              CustomPopOutInput(
                icon: Icons.mail_outline,
                hint: 'Email',
                gradient: myGradient,
              ),

              const SizedBox(height: 20),

              // CAMPO NOME
              CustomPopOutInput(
                icon: Icons.person_outline,
                hint: 'Nome',
                gradient: myGradient,
              ),

              const SizedBox(height: 20),

              // CAMPO PASSWORD (com ícone de 3 pontos do design)
              CustomPopOutInput(
                icon: Icons.more_horiz, // Ícone que representa os "..." do print
                hint: 'Password',
                gradient: myGradient,
                isPassword: true,
                isObscure: _isObscure,
                onToggleVisibility: () {
                  setState(() => _isObscure = !_isObscure);
                },
              ),

              const SizedBox(height: 20),

              // CAMPO CONFIRMA PASSWORD
              CustomPopOutInput(
                icon: Icons.more_horiz,
                hint: 'Confirma a tua Password', 
                gradient: myGradient,
                isPassword: true,
                isObscure: _isObscureConfirm,
                onToggleVisibility: () {
                  setState(() => _isObscureConfirm = !_isObscureConfirm);
                },
              ),

              const SizedBox(height: 40),

              // BOTÃO CRIAR CONTA
              CustomGradientButton(
                text: 'Criar Conta',
                gradient: myGradient,
                onPressed: () {
                  // Lógica para registar o utilizador
                  print('A criar conta...');
                },
              ),
              
              const SizedBox(height: 30),
            ],
          ),
        ),
      ),
    );
  }
}